    "SendQuoteLambdaVersionrlEtfy5R80r0rB3e8tLC1E8CKwS5d1jQuyZPTut8tc": {
      "Type": "AWS::Lambda::Version",
      "DeletionPolicy": "Retain",
      "Properties": {
        "FunctionName": {
          "Ref": "SendQuoteLambdaFunction"
